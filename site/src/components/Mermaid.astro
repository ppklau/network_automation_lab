---
interface Props {
  code: string;
}
const { code } = Astro.props;
---

<div class="mermaid-wrapper not-content">
  <pre class="mermaid">{code}</pre>
  <button class="mermaid-expand-btn" aria-label="View diagram full size">
    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2"
         stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/>
      <line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>
    </svg>
    View full size
  </button>
</div>

<script>
  import mermaid from 'mermaid';

  function getTheme(): 'dark' | 'default' {
    return document.documentElement.dataset.theme === 'dark' ? 'dark' : 'default';
  }

  // ── Modal ────────────────────────────────────────────────────────────────────

  function getOrCreateModal(): HTMLElement {
    let modal = document.getElementById('mermaid-modal');
    if (modal) return modal;

    modal = document.createElement('div');
    modal.id = 'mermaid-modal';
    modal.setAttribute('hidden', '');
    modal.innerHTML = `
      <div class="mermaid-modal-backdrop"></div>
      <div class="mermaid-modal-inner">
        <button class="mermaid-modal-close" aria-label="Close diagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
        <div class="mermaid-modal-diagram"></div>
      </div>
    `;
    document.body.appendChild(modal);
    modal.querySelector('.mermaid-modal-backdrop')!.addEventListener('click', closeModal);
    modal.querySelector('.mermaid-modal-close')!.addEventListener('click', closeModal);
    return modal;
  }

  function openModal(svg: SVGElement) {
    const modal = getOrCreateModal();
    const diagramEl = modal.querySelector('.mermaid-modal-diagram')!;
    diagramEl.innerHTML = '';
    diagramEl.appendChild(svg.cloneNode(true));
    modal.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    const modal = document.getElementById('mermaid-modal');
    if (modal) modal.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // ── Expand button — event delegation ─────────────────────────────────────────
  // One listener on document catches all clicks via bubbling. No per-button
  // wiring needed, so there are no timing or scope-attribute issues.

  document.addEventListener('click', (e: MouseEvent) => {
    const btn = (e.target as Element).closest('.mermaid-expand-btn');
    if (!btn) return;
    const svg = btn.closest('.mermaid-wrapper')?.querySelector('svg');
    if (svg) openModal(svg as SVGElement);
  });

  // ── Render ───────────────────────────────────────────────────────────────────

  function cacheWrapperSources() {
    document.querySelectorAll('.mermaid-wrapper').forEach((wrapper) => {
      if (wrapper.hasAttribute('data-source')) return;
      const pre = wrapper.querySelector('pre.mermaid');
      if (pre) wrapper.setAttribute('data-source', pre.textContent?.trim() ?? '');
    });
  }

  // Monotonically increasing so every mermaid.render() call gets a unique SVG id.
  let diagramSeq = 0;
  // Concurrency guard — mermaid.render() is async; queue at most one pending call.
  let rendering = false;
  let renderQueued = false;

  async function renderMermaid() {
    if (rendering) {
      renderQueued = true;
      return;
    }
    rendering = true;
    renderQueued = false;

    try {
      cacheWrapperSources();

      const isDark = getTheme() === 'dark';
      mermaid.initialize({
        startOnLoad: false,
        suppressErrorRendering: true,
        theme: getTheme(),
        securityLevel: 'loose',
        fontFamily: 'inherit',
        ...(isDark && {
          themeVariables: {
            quadrantXAxisTextFill: '#e2e8f0',
            quadrantYAxisTextFill: '#e2e8f0',
            quadrantTitleFill: '#e2e8f0',
            quadrantPointTextFill: '#e2e8f0',
          },
        }),
      });

      // Use mermaid.render(id, sourceString) rather than mermaid.run() so we
      // pass the cached source string directly — no DOM round-trip that could
      // produce garbled text or a "Syntax error in text" on re-render.
      for (const wrapper of document.querySelectorAll<HTMLElement>('.mermaid-wrapper[data-source]')) {
        const source = wrapper.getAttribute('data-source')!;
        const id = `mermaid-d${++diagramSeq}`;
        try {
          const { svg } = await mermaid.render(id, source);
          // Remove previous rendered output, leaving the expand button in place.
          for (const child of Array.from(wrapper.children)) {
            if (!child.classList.contains('mermaid-expand-btn')) child.remove();
          }
          const container = document.createElement('div');
          container.innerHTML = svg;
          const btn = wrapper.querySelector('.mermaid-expand-btn');
          btn ? wrapper.insertBefore(container, btn) : wrapper.appendChild(container);
        } catch (err) {
          console.error('mermaid: render error —', err);
          // Clean up any temp elements mermaid may have left in the DOM.
          document.getElementById(`d${id}`)?.remove();
        }
      }
    } finally {
      rendering = false;
      if (renderQueued) {
        renderQueued = false;
        renderMermaid();
      }
    }
  }

  document.addEventListener('astro:page-load', renderMermaid);

  // Re-render when the user switches light/dark theme.
  // Debounced so we wait for Starlight's View Transition to settle before
  // reading the new theme and re-initialising mermaid.
  let renderTimer: ReturnType<typeof setTimeout> | null = null;

  const observer = new MutationObserver((mutations) => {
    for (const m of mutations) {
      if (m.attributeName === 'data-theme') {
        if (renderTimer !== null) clearTimeout(renderTimer);
        renderTimer = setTimeout(() => {
          renderTimer = null;
          renderMermaid();
        }, 60);
        break;
      }
    }
  });
  observer.observe(document.documentElement, { attributes: true });
</script>

<style>
  .mermaid-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 1.5rem 0;
    overflow-x: auto;
  }

  .mermaid-wrapper :global(svg) {
    max-width: 100%;
    height: auto;
  }

  /* Hidden until Mermaid renders the SVG into the wrapper */
  .mermaid-expand-btn {
    display: none;
  }

  .mermaid-wrapper:has(svg) .mermaid-expand-btn {
    display: inline-flex;
  }
</style>
