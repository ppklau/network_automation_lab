{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://acme-investments.internal/schemas/intent.schema.json",
  "title": "ACME Investments — Design Intent Schema",
  "description": "Validates design intent files in design_intents/*.yml. Each file is a Layer 2 document containing one or more INTENT-NNN definitions under an 'intents:' list.",
  "type": "object",
  "required": ["intents"],
  "additionalProperties": true,

  "properties": {

    "intents": {
      "type": "array",
      "minItems": 1,
      "description": "List of intent definitions in this file.",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "requirement_refs",
          "assertion_type"
        ],
        "additionalProperties": true,

        "properties": {

          "id": {
            "type": "string",
            "pattern": "^INTENT-\\d{3}$",
            "description": "Unique intent identifier. E.g. INTENT-001."
          },

          "title": {
            "type": "string",
            "minLength": 10,
            "description": "Human-readable intent title."
          },

          "requirement_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^REQ-\\d{3}$"
            },
            "description": "Layer 1 requirement IDs this intent satisfies."
          },

          "regulatory_refs": {
            "type": "array",
            "items": { "type": "string" }
          },

          "related_intents": {
            "type": "array",
            "items": { "type": "string", "pattern": "^INTENT-\\d{3}$" }
          },

          "description": { "type": "string" },
          "rationale":   { "type": "string" },

          "assertion_type": {
            "type": "string",
            "enum": [
              "automated",
              "batfish",
              "batfish_check",
              "sot_check",
              "sot_checks",
              "operational",
              "conditional",
              "mixed"
            ],
            "description": "How this intent is verified. 'batfish_check' means Batfish assertions + SoT checks. 'operational' means compliance_report.yml post-push checks only."
          },

          "sites_in_scope": {
            "type": "array",
            "items": { "type": "string" }
          },

          "batfish_check": {
            "description": "Batfish assertion specification. Can be an object with test_file+assertions, or an array of assertion objects.",
            "oneOf": [
              {
                "type": "object",
                "required": ["test_file", "assertions"],
                "properties": {
                  "test_file": { "type": "string" },
                  "assertions": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["id", "description"],
                      "properties": {
                        "id": { "type": "string", "pattern": "^BA-\\d{3,4}$" },
                        "function":       { "type": "string" },
                        "description":    { "type": "string" },
                        "pybatfish_api":  { "type": "string" },
                        "parameters":     { "type": "object" },
                        "expected_result": { "type": "string" },
                        "failure_action": { "type": "string" },
                        "rationale":      { "type": "string" },
                        "pipeline_action": { "type": "string" }
                      }
                    }
                  }
                }
              },
              {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "description"],
                  "properties": {
                    "id":          { "type": "string", "pattern": "^BA-\\d{3,4}$" },
                    "description": { "type": "string" },
                    "api":         { "type": "string" },
                    "pipeline_action": { "type": "string" }
                  }
                }
              }
            ]
          },

          "sot_checks": {
            "type": "array",
            "description": "SoT pre-render checks (SC-NNN) enforced by validate_sot.py.",
            "items": {
              "type": "object",
              "required": ["id", "description"],
              "additionalProperties": true,
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^SC-\\d{3,4}$"
                },
                "description":    { "type": "string" },
                "check_type":     { "type": "string" },
                "target_devices": {},
                "field_path":     { "type": "string" },
                "severity": {
                  "type": "string",
                  "enum": ["critical", "high", "medium", "low"]
                },
                "check_target":    { "type": "string" },
                "pipeline_action": { "type": "string" },
                "rationale":       { "type": "string" },
                "pattern":         { "type": "string" },
                "must_be_absent":  { "type": "boolean" }
              }
            }
          },

          "violation": {
            "type": "object",
            "properties": {
              "severity": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low"]
              },
              "pipeline_action": { "type": "string" },
              "notify":          { "type": "array", "items": { "type": "string" } },
              "escalation_path": { "type": "string" },
              "remediation": {
                "description": "Remediation steps — string (multi-line block scalar) or list.",
                "oneOf": [
                  { "type": "string" },
                  { "type": "array", "items": { "type": "string" } }
                ]
              }
            }
          }
        }
      }
    }
  }
}
